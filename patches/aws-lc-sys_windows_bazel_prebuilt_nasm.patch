         && !is_disable_prebuilt_nasm() // not prevented by feature
         // permitted by environment or by feature
+        && (use_prebuilt_for_bazel_windows || !test_nasm_command())
         && (Some(true) == allow_prebuilt_nasm() || is_prebuilt_nasm())
 }
 
