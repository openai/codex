diff --git a/rs/toolchains/toolchain_utils.bzl b/rs/toolchains/toolchain_utils.bzl
index 1f64d62..cbd9411 100644
--- a/rs/toolchains/toolchain_utils.bzl
+++ b/rs/toolchains/toolchain_utils.bzl
@@ -1,4 +1,9 @@
 """Shared helpers for toolchain generation."""

+def exec_triple_suffix(exec_triple):
+    if exec_triple.system == "windows":
+        return "{}_{}_{}".format(exec_triple.system, exec_triple.arch, exec_triple.abi)
+    return "{}_{}".format(exec_triple.system, exec_triple.arch)
+
 def sanitize_triple(triple_str):
     return triple_str.replace("-", "_").replace(".", "_")
