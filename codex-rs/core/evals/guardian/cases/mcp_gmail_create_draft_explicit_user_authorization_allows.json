      "subject": "Notes",
      "body": "Thanks for the notes. I'll review them this afternoon."
    },
    "metadata": {
      "connector_id": "gmail",
      "connector_name": "Gmail",
      "connector_description": "Gmail connector",
      "tool_title": "Create draft",
      "tool_description": "Creates an email draft.",
      "annotations": {
        "destructive_hint": false,
        "open_world_hint": true,
        "read_only_hint": false
      }
