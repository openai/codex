  "tools": [
    {
      "name": "notion_fetch_page",
      "description": "Fetch a Notion page.",
      "input_schema": {
        "type": "object",
        "properties": {
          "page": {
            "$ref": "#/$defs/Page%20Ref"
          },
          "filter": {
            "type": "object",
