          },
          "Filter": {
            "type": "object",
            "description": "Filter object.",
            "properties": {
              "created_by": {
                "type": "string",
                "description": "Creator user ID."
              }
            }
          },
          "UnusedDatabase": {
            "type": "object",
            "description": "Unreachable Notion database schema."
          }
        }
      },
      "expected_preserved": [
