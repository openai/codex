{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AlarmDelivery": {
      "enum": [
        "after-turn",
        "steer-current-turn"
      ],
      "type": "string"
    },
    "ThreadAlarm": {
      "properties": {
        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "cronExpression": {
          "type": "string"
        },
        "delivery": {
          "$ref": "#/definitions/AlarmDelivery"
        },
        "id": {
          "type": "string"
        },
        "lastRunAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "nextRunAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "prompt": {
          "type": "string"
        },
        "runOnce": {
          "type": "boolean"
        }
      },
      "required": [
        "createdAt",
        "cronExpression",
        "delivery",
        "id",
        "prompt",
        "runOnce"
      ],
      "type": "object"
    }
  },
  "properties": {
    "alarms": {
      "items": {
        "$ref": "#/definitions/ThreadAlarm"
      },
      "type": "array"
    },
    "threadId": {
      "type": "string"
    }
  },
  "required": [
    "alarms",
    "threadId"
  ],
  "title": "ThreadAlarmUpdatedNotification",
  "type": "object"
}