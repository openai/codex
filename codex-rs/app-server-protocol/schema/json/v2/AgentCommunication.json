{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AgentCommunicationKind": {
      "enum": [
        "initialTask",
        "message",
        "followup",
        "result"
      ],
      "type": "string"
    },
    "AgentCommunicationState": {
      "enum": [
        "created",
        "enqueued"
      ],
      "type": "string"
    }
  },
  "properties": {
    "content": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "$ref": "#/definitions/AgentCommunicationKind"
    },
    "occurredAtMs": {
      "format": "int64",
      "type": "integer"
    },
    "receiverThreadId": {
      "type": "string"
    },
    "senderThreadId": {
      "type": "string"
    },
    "sourceCallId": {
      "type": [
        "string",
        "null"
      ]
    },
    "state": {
      "$ref": "#/definitions/AgentCommunicationState"
    }
  },
  "required": [
    "content",
    "id",
    "kind",
    "occurredAtMs",
    "receiverThreadId",
    "senderThreadId",
    "sourceCallId",
    "state"
  ],
  "title": "AgentCommunication",
  "type": "object"
}