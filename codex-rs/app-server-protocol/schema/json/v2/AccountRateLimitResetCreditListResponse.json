{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "RateLimitResetCredit": {
      "properties": {
        "expiresAt": {
          "description": "Unix timestamp in seconds when the credit expires, or `null` if it does not expire.",
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "grantedAt": {
          "description": "Unix timestamp in seconds when the credit was granted.",
          "format": "int64",
          "type": "integer"
        },
        "id": {
          "description": "Opaque backend identifier for this reset credit.",
          "type": "string"
        },
        "resetType": {
          "$ref": "#/definitions/RateLimitResetType"
        },
        "status": {
          "$ref": "#/definitions/RateLimitResetCreditStatus"
        }
      },
      "required": [
        "grantedAt",
        "id",
        "resetType",
        "status"
      ],
      "type": "object"
    },
    "RateLimitResetCreditStatus": {
      "enum": [
        "available",
        "redeeming",
        "redeemed"
      ],
      "type": "string"
    },
    "RateLimitResetType": {
      "enum": [
        "codexRateLimits"
      ],
      "type": "string"
    }
  },
  "description": "Available reset credits returned by the backend.\n\nThis is a non-pageable snapshot because the upstream API does not expose a cursor. `data` contains details for at most 10 credits, so it can contain fewer rows than `availableCount`.",
  "properties": {
    "availableCount": {
      "format": "int64",
      "type": "integer"
    },
    "data": {
      "items": {
        "$ref": "#/definitions/RateLimitResetCredit"
      },
      "type": "array"
    }
  },
  "required": [
    "availableCount",
    "data"
  ],
  "title": "AccountRateLimitResetCreditListResponse",
  "type": "object"
}