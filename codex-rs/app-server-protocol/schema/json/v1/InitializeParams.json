{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ClientInfo": {
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "type": "object"
    },
    "InitializeCapabilities": {
      "description": "Client-declared capabilities negotiated during initialize.",
      "properties": {
        "experimentalApi": {
          "default": false,
          "description": "Opt into receiving experimental API methods and fields.",
          "type": "boolean"
        },
        "mcpClientCapabilities": {
          "anyOf": [
            {
              "$ref": "#/definitions/McpClientCapabilities"
            },
            {
              "type": "null"
            }
          ],
          "description": "Passive MCP capabilities supported by this app-server client."
        },
        "optOutNotificationMethods": {
          "description": "Exact notification method names that should be suppressed for this connection (for example `thread/started`).",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "requestAttestation": {
          "default": false,
          "description": "Opt into `attestation/generate` requests for upstream `x-oai-attestation`.",
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "McpAppUiCapability": {
      "description": "Passive MCP App presentation features supported by the active host.",
      "enum": [
        "webView",
        "declarativeUi"
      ],
      "type": "string"
    },
    "McpClientCapabilities": {
      "description": "Passive MCP capabilities supplied by the active Codex host.",
      "properties": {
        "appUi": {
          "items": {
            "$ref": "#/definitions/McpAppUiCapability"
          },
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "appUi"
      ],
      "type": "object"
    }
  },
  "properties": {
    "capabilities": {
      "anyOf": [
        {
          "$ref": "#/definitions/InitializeCapabilities"
        },
        {
          "type": "null"
        }
      ]
    },
    "clientInfo": {
      "$ref": "#/definitions/ClientInfo"
    }
  },
  "required": [
    "clientInfo"
  ],
  "title": "InitializeParams",
  "type": "object"
}