load("//:defs.bzl", "MACOS_WEBRTC_RUSTC_LINK_FLAGS", "codex_rust_crate", "runfile_env_binary")
load("//bazel/platforms:release_binaries.bzl", "multiplatform_binaries")

codex_rust_crate(
    name = "cli",
    crate_name = "codex_cli",
    extra_binaries = [
        "//codex-rs/bwrap:bwrap",
    ],
    rustc_flags_extra = MACOS_WEBRTC_RUSTC_LINK_FLAGS,
)

multiplatform_binaries(
    name = "codex",
)

runfile_env_binary(
    name = "codex-with-code-mode",
    binary = ":codex",
    runfile_env = {
        "//codex-rs/code-mode-host:codex-code-mode-host": "CODEX_CODE_MODE_HOST_PATH",
    },
)
