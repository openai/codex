load("//:defs.bzl", "codex_rust_crate")

codex_rust_crate(
    name = "rustls-provider",
    crate_name = "codex_utils_rustls_provider",
    test_sizes = {
        "rustls-provider-preinstalled-test-windows-cross": "medium",
