# rusty_v8 still publishes Windows bindings under MSVC filenames upstream.
# We copy them to gnullvm-named outputs so our release pair stays consistent
# with the toolchain we actually target.
copy_file(
    name = "src_binding_release_x86_64_pc_windows_gnullvm",
    src = "@v8_crate_146_4_0//:src_binding_release_x86_64_pc_windows_msvc",
    out = "src_binding_release_x86_64-pc-windows-gnullvm.rs",
)

copy_file(
    name = "src_binding_release_aarch64_pc_windows_gnullvm",
    src = "@v8_crate_146_4_0//:src_binding_release_aarch64_pc_windows_msvc",
    out = "src_binding_release_aarch64-pc-windows-gnullvm.rs",
)

